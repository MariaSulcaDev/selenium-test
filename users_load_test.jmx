            <stringProp name="Argument.name">base_path</stringProp>
            <stringProp name="Argument.value">/api/users</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="institution_id" elementType="Argument">
            <stringProp name="Argument.name">institution_id</stringProp>
            <stringProp name="Argument.value">7fb4d651-53e0-4f45-b78a-25fee819767f</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
